# Copy to .env.local
#
# Leave VITE_SUPABASE_URL unset for local dev — the app then calls the
# same-origin /supabase path that vite.config.ts proxies to the local stack.
# This is what makes a shared tunnel link work for other people.
# Point it at a cloud project only when deploying:
# VITE_SUPABASE_URL=https://<project>.supabase.co

VITE_SUPABASE_ANON_KEY=<run `supabase status -o env` and copy ANON_KEY>
